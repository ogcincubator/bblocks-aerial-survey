<https://ogcincubator.github.io/bblocks-aerial-survey/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - Aerial Survey Metadata" ;
    dct:abstract """A building blocks architecture for supporting the description of aerial surveys and the data products generated
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """Aerial surveys have many facets that may impact the interpretation of the generated data and the ability to accurately re-survey. 

Accordingly this model supports both coarse and fine-grained descriptions of flight plans and systems.

The goal is to identify and re-use existing OGC standards that address common parts of the domain challenge.

This includes a detail description of an actual flight path using the moving features standard, which allows for correlation of changing conditions in time and space.

Metadata using OGC API records, STAC and DCAT is enabled - and ISO or other metadata record models may be introduced as required,
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-04-20T08:39:07.937158"^^xsd:dateTime ;
    owl:imports <https://ogcincubator.github.io/bblocks-movingfeatures/build/register.json>,
        <https://ogcincubator.github.io/bblocks-stac/build/register.json>,
        <https://ogcincubator.github.io/geodcat-ogcapi-records/build/register.json>,
        <https://opengeospatial.github.io/bblocks/register.json>,
        <https://opengeospatial.github.io/ogcapi-sosa/build/register.json> ;
    skos:hasTopConcept <bblocks://ogc.domain.aerial-survey.stac-aerial-survey>,
        <bblocks://ogc.domain.aerial-survey.survey-process-prov> ;
    skos:prefLabel "Building Blocks - Aerial Survey Metadata" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-aerial-survey/build/bblocks.jsonld> ],
        [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-aerial-survey/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-aerial-survey/build/register.json> ] ;
    foaf:homepage <https://ogcincubator.github.io/bblocks-aerial-survey/> ;
    bblocks:hasValidationReport <https://ogcincubator.github.io/bblocks-aerial-survey/build/tests/report.html> .

